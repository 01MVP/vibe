---
import type { TestDefinition } from "../data/tests";

interface Props {
  test: TestDefinition;
}

const { test } = Astro.props;
---

<section class="quiz-shell" id="quiz-app" data-test-id={test.id} aria-labelledby="exam-title">
  <div class="challenge-banner" id="challenge-banner" hidden>
    <span id="challenge-copy"></span>
    <button type="button" id="challenge-close" aria-label="关闭挑战提示">×</button>
  </div>

  <div id="start-view" class="quiz-start">
    <div class="start-mark" aria-hidden="true">
      <span>{test.index}</span>
      <strong>{test.symbol}</strong>
    </div>
    <div class="start-copy">
      <p class="micro-label">{test.eyebrow}</p>
      <h2 id="exam-title">{test.startTitle}</h2>
      <p>{test.startCopy}</p>
      <div class="start-meta">
        <span>{test.duration}</span>
        <span>{test.dimensions.map((dimension) => dimension.label).join(" / ")}</span>
      </div>
      <button class="primary-button" type="button" id="start-test">{test.cta}</button>
    </div>
  </div>

  <div id="question-view" class="question-view" hidden>
    <div class="question-toolbar">
      <button class="text-button" type="button" id="exit-test">← 退出</button>
      <span id="answered-count">0 / {test.questions.length}</span>
    </div>

    <div class="progress-track" aria-hidden="true"><span id="progress-bar"></span></div>

    <article class="question-card" id="question-card">
      <div class="question-kicker">
        <span id="question-position">01 / {String(test.questions.length).padStart(2, "0")}</span>
        <span id="question-difficulty">热身</span>
        <span id="question-category"></span>
      </div>
      <p class="question-setup" id="question-setup"></p>
      <h2 id="question-prompt"></h2>
      <div class="option-list" id="option-list"></div>
    </article>

    <div class="answer-feedback" id="answer-feedback" hidden aria-live="polite">
      <div>
        <p class="feedback-verdict" id="feedback-verdict"></p>
        <p class="feedback-explanation" id="feedback-explanation"></p>
        <p class="feedback-takeaway" id="feedback-takeaway"></p>
        <pre class="feedback-command" id="feedback-command" hidden><code></code></pre>
        <div class="feedback-sources" id="feedback-sources"></div>
      </div>
      <button class="primary-button" type="button" id="next-question">下一题 →</button>
    </div>
  </div>

  <div id="result-view" class="result-view" hidden>
    <div class="result-card" id="result-card">
      <div class="result-card-head">
        <p class="micro-label" id="result-mode-note">{test.shortTitle}</p>
        <p class="result-score"><span id="result-score">0</span><small>/100</small></p>
      </div>
      <p class="result-tier" id="result-tier"></p>
      <div class="type-lockup">
        <strong id="result-code"></strong>
        <span id="result-icon" aria-hidden="true"></span>
      </div>
      <h2 id="result-title"></h2>
      <p class="result-quote" id="result-quote"></p>
      <div class="dimension-list" id="dimension-list">
        {test.dimensions.map((dimension, index) => (
          <div>
            <span>{dimension.label}</span>
            <i><b data-dimension-bar={index}></b></i>
            <strong data-dimension-value={index}>0</strong>
          </div>
        ))}
      </div>
      <div class="result-gaps-wrap">
        <p>你的补课清单</p>
        <ul id="result-gaps"></ul>
      </div>
      <p class="result-roast" id="result-roast"></p>
      <small class="result-url">vibe.01mvp.com/{test.slug}</small>
    </div>
    <div class="result-actions">
      <button class="primary-button" type="button" id="share-result">保存结果图</button>
      <button class="secondary-button" type="button" id="retry-test">再测一次</button>
      <a class="text-button" href="/">其他测试</a>
    </div>
    <p class="share-status" id="share-status" aria-live="polite"></p>
  </div>
</section>

<div class="confetti-layer" id="confetti-layer" aria-hidden="true"></div>

<script>
  import "../scripts/quiz";
</script>
