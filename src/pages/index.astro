---
import BaseLayout from "../layouts/BaseLayout.astro";
import QuizApp from "../components/QuizApp.astro";

const title = "Vibe Coding 月考｜测出你的 Vibe 类型";
const description = "9 道题，8 种结果，测出你的 Vibe Coding 类型。";
---

<BaseLayout title={title} description={description}>
  <header class="site-header">
    <a class="brand-link" href="/" aria-label="Vibe Coding 月考首页">
      <img src="/brand/01mvp-lockup-horizontal.svg" alt="01MVP" width="158" height="39" />
      <span>VIBE EXAM</span>
    </a>
    <a class="header-link" href="https://github.com/01MVP/vibe" target="_blank" rel="noreferrer">GitHub ↗</a>
  </header>

  <main class="page-shell">
    <section class="hero" aria-labelledby="hero-title">
      <p class="eyebrow">ISSUE 001 · JULY 2026</p>
      <h1 id="hero-title">测测你的<br />Vibe Coding 类型</h1>
      <p>9 道题 · 8 种结果</p>
    </section>

    <QuizApp />

    <p class="page-note">娱乐测试，不是职业资格。</p>
  </main>

  <footer class="site-footer">
    <span>01MVP · VIBE EXAM</span>
    <a href="https://01mvp.com" target="_blank" rel="noreferrer">01mvp.com ↗</a>
  </footer>
</BaseLayout>
